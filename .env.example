# ============================================================================
# claude-faces — environment contract
# ============================================================================
#
# Copy this file to .env.local and fill in ONLY what you need:
#
#     cp .env.example .env.local
#
# EVERY key below is OPTIONAL. The app degrades gracefully:
#
#   - No chat brain key at all  -> the UI shows a friendly "configure a brain
#     or wire your running agent" state; the face stays interactive.
#   - No OPENAI_API_KEY / GROQ_API_KEY -> speech-to-text falls back to the
#     in-browser Whisper model (WebGPU/WASM, private, offline) and speech-out
#     falls back to the browser Web Speech API. Zero infra, zero cost.
#   - The Mode B agent-bridge only appears in the UI when its endpoint is
#     actually reachable (and, in production, only when explicitly allowed).
#
# SECURITY RULE (non-negotiable): every value here is SERVER-SIDE ONLY. These
# are read exclusively inside Next.js route handlers (app/api/*). NEVER prefix
# any of them with the client-exposed NEXT-PUBLIC prefix — that would ship your
# secrets to the browser. Keep them unprefixed and server-only.
#
# Chat-brain selection priority (when the user has not explicitly picked one):
#     ANTHROPIC  ->  OPENROUTER  ->  GROQ  ->  agent-bridge (Mode B)
# See docs/env-contract.md for the full contract.
# ============================================================================


# ----------------------------------------------------------------------------
# Mode A — fresh API brains (hosted, work on Vercel; all optional)
# ----------------------------------------------------------------------------

# Anthropic (Claude) chat brain. Highest priority when set.
ANTHROPIC_API_KEY=
# Override the default Anthropic model the picker preselects.
ANTHROPIC_DEFAULT_MODEL=

# OpenRouter chat brain — also fronts Nous Hermes + hundreds of other models.
OPENROUTER_API_KEY=
# Override the default OpenRouter model (e.g. a pinned Hermes id).
OPENROUTER_DEFAULT_MODEL=

# Groq chat brain — very-low-latency inference. The SAME key also enables
# hosted Whisper STT (whisper-large-v3-turbo) in /api/transcribe.
GROQ_API_KEY=
# Override the default Groq model the picker preselects.
GROQ_DEFAULT_MODEL=

# OpenAI — unlocks hosted Whisper STT fallback AND gpt-4o-mini-tts voice-out.
OPENAI_API_KEY=


# ----------------------------------------------------------------------------
# Mode B — agent-bridge: reuse an ALREADY-RUNNING agent as the brain (optional)
# ----------------------------------------------------------------------------
# Wire the face to an agent you already run so it reuses that agent's memory,
# tools, and persona instead of making a stateless API call. Reachable directly
# on localhost / self-host, or from Vercel only via a public HTTPS tunnel.

# Which kind of running agent to bridge to.
# One of: hermes | openclaw | claude-code | ollama | openai-compatible
AGENT_BRIDGE_KIND=
# Base URL of the running agent (e.g. http://localhost:11434 for Ollama,
# or a public https tunnel URL when serving from Vercel).
AGENT_BRIDGE_URL=
# Auth token/key for the bridged agent, if it requires one.
AGENT_BRIDGE_KEY=
# Override the model/thread the bridged agent should use, if applicable.
AGENT_BRIDGE_MODEL=

# Hermes-compatible convenience aliases for a Hermes api_server. If set, these
# are used for the hermes bridge kind (equivalent to AGENT_BRIDGE_URL/KEY).
HERMES_API_BASE_URL=
HERMES_API_KEY=


# ----------------------------------------------------------------------------
# Hosted STT (speech-to-text) tuning knobs (optional)
# ----------------------------------------------------------------------------
# These tune the OpenAI hosted-transcription fallback in /api/transcribe.
# (Groq STT uses whisper-large-v3-turbo automatically when GROQ_API_KEY is set.)

# OpenAI transcription model. Default: whisper-1
OPENAI_TRANSCRIBE_MODEL=whisper-1
# Force a transcription language (ISO-639-1, e.g. en, pt). Blank = auto-detect.
OPENAI_TRANSCRIBE_LANGUAGE=
# Optional vocab/style prompt to bias transcription (names, jargon, etc.).
OPENAI_TRANSCRIBE_PROMPT=


# ----------------------------------------------------------------------------
# Deploy knobs (optional)
# ----------------------------------------------------------------------------

# Set to 1 when self-hosting (e.g. Docker on your own VPS next to the agent).
# Relaxes the Vercel-only assumptions so Mode B can reach a private-network URL.
SELF_HOST=

# By default a serverless Vercel function will NOT expose an agent-bridge that
# points at a private/localhost URL it cannot reach. Set to 1 to allow the
# agent-bridge in production when you KNOW the URL is a public HTTPS/tunnel.
ALLOW_AGENT_BRIDGE_IN_PROD=
