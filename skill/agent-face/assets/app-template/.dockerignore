# Keep the build context small & reproducible: node_modules and build output
# are regenerated inside the image (npm ci -> next build), and secrets/logs
# must never enter an image layer.

# dependencies (reinstalled via npm ci in the deps stage)
node_modules

# build output (regenerated by `next build` inside the image)
.next
out
build
*.tsbuildinfo

# generated at build time from node_modules by scripts/setup-vad-assets.mjs
public/vad

# ML model cache (browser Whisper / Kokoro downloads)
public/models

# env — never bake secrets into an image layer
.env
.env*.local

# vercel
.vercel

# testing / coverage
coverage
playwright-report
test-results

# vcs & tooling
.git
.github
.gitignore

# docs, harness, and reference material not needed to run the app
docs
reference
skill
progress.txt
*.log

# docker artifacts themselves
Dockerfile
.dockerignore
docker-compose.yml

# misc
.DS_Store
README.md
CLAUDE.md
